# GitHub App Configuration
GITHUB_APP_ID=your_app_id
GITHUB_APP_SLUG=your_app_slug
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret
GITHUB_PRIVATE_KEY_PATH=/path/to/private-key.pem

# Frontend URL (used for CORS and OAuth redirect)
FRONTEND_URL=http://localhost:5173

# Session encryption key (hex-encoded 32-byte key for AES-256-GCM).
# Generate with: php -r "echo bin2hex(random_bytes(32));"
# If empty, sessions are stored as plain JSON (not recommended for production).
SESSION_ENCRYPTION_KEY=
