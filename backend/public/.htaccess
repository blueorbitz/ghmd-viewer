DirectoryIndex disabled

RewriteEngine On
RewriteBase /

# Block access to internal app directory
RewriteRule ^_app/ - [F,L]

# Route /api/* requests to index.php
RewriteRule ^api/ index.php [L,QSA]

# If the request is for an existing file or directory, serve it directly
# (but skip the document root itself so it falls through to SPA)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_URI} !^/$
RewriteRule ^ - [L]

# For everything else (including /), serve the SPA
RewriteRule ^ client/index.html [L]
